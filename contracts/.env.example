# Deployer wallet private key — NEVER commit the real value
DEPLOYER_PRIVATE_KEY=0x

# Wallet address that receives all USDC payments (credits, edits, tips)
# TODO: set to your treasury wallet address
TREASURY_ADDRESS=0x

# Wallet that can update the treasury and set prices (can be same as treasury for solo dev)
# TODO: set to your owner/operator wallet address
OWNER_ADDRESS=0x

# Base mainnet RPC (get a free key from Alchemy or QuickNode for production)
BASE_RPC_URL=https://mainnet.base.org

# Basescan API key for contract verification (optional, get from basescan.org)
BASESCAN_API_KEY=
